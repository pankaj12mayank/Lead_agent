{
  "name": "leadpilot",
  "private": true,
  "description": "LeadPilot — one-command local dev (API + Vite)",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "test": "pytest && npm run test --prefix frontend",
    "test:api": "pytest",
    "test:web": "npm run test --prefix frontend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
