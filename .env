# --- App ---
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=*

# --- Scraper (Playwright) ---
SCRAPER_DELAY_MIN_SECONDS=3
SCRAPER_DELAY_MAX_SECONDS=5
SCRAPER_MAX_LEADS_DEFAULT=20
SCRAPER_MAX_LEADS_HARD_CAP=50
SCRAPER_MANUAL_LOGIN_DEFAULT_SECONDS=180

# --- Lead scoring (optional industry bonus for ``industry_match`` factor) ---
# SCORING_BENCHMARK_INDUSTRY=software

# --- Storage ---
STORAGE_MODE=csv
CSV_FILE_PATH=data/leads.csv
SQLITE_DB_PATH=database/leads.db
POSTGRES_DSN=

# --- API meta DB (users, history, SQLAlchemy outreach/sessions/settings tables) ---
API_META_DB_PATH=database/api_meta.db

# --- Monorepo dirs ---
EXPORTS_DIR=exports
SESSIONS_DIR=sessions
LOGS_DIR=logs

# --- Auth (MVP: local JWT) ---
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Admin console (/admin) — separate from app users; both required to enable admin login ---
# Copy these lines into a real `.env` file next to `config.py` (repo root), then restart the API.
# Values in `frontend/.env` are NOT read by Python — admin login will fail if ADMIN_* is only there.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=123456

# --- AI (Ollama) ---
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=llama3
USE_OLLAMA=true
FREE_API_MODE=false
PROMPTS_DIR=prompts

# Message pack generator (retries, timeouts, per-family model tags)
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=3
OLLAMA_MODEL_LLAMA3=llama3
OLLAMA_MODEL_MISTRAL=mistral
OLLAMA_MODEL_DEEPSEEK=deepseek-r1

# --- Optional API keys ---
API_KEYS=

# --- SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SENDER_NAME=Lead Engine
SENDER_EMAIL=
EMAIL_SIGNATURE=

# --- Frontend (Vite) — optional frontend/.env ---
# Dev: leave empty to use Vite /api proxy. Prod build: set browser-facing API URL.
# VITE_API_URL=http://127.0.0.1:8000
